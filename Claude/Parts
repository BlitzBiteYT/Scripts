local function showNotification()
    local notif = Instance.new("ScreenGui")
    notif.Name = "PartInspectorNotif"
    notif.ResetOnSpawn = false
    notif.IgnoreGuiInset = true
    notif.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notif.Parent = LocalPlayer.PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 56)
    frame.Position = UDim2.new(0.5, -150, 1, -80)
    frame.BackgroundColor3 = Color3.fromRGB(10, 12, 18)
    frame.BorderSizePixel = 0
    frame.Parent = notif
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0, 180, 255)
    stroke.Thickness = 1.5
    stroke.Parent = frame

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -16, 1, 0)
    lbl.Position = UDim2.new(0, 8, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = "🔍 Part Inspector v2.0 Loaded!\n⚡ Double-click any part to inspect"
    lbl.TextColor3 = Color3.fromRGB(200, 230, 255)
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.ZIndex = 2
    lbl.Parent = frame

    -- Slide up
    frame.Position = UDim2.new(0.5, -150, 1, 70)
    TweenService:Create(frame,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = UDim2.new(0.5, -150, 1, -80)}
    ):Play()

    task.delay(3.5, function()
        TweenService:Create(frame,
            TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {Position = UDim2.new(0.5, -150, 1, 70), BackgroundTransparency = 1}
        ):Play()
        task.delay(0.4, function()
            notif:Destroy()
        end)
    end)
