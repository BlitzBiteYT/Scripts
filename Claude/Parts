-- ─── DOUBLE CLICK DETECTION ──────────────────────────────────
local lastClickTime  = 0
local lastClickedObj = nil
local highlight      = nil

Mouse.Button1Down:Connect(function()
    local now    = tick()
    local target = Mouse.Target

    if target and target:IsA("BasePart") then
        if target == lastClickedObj and (now - lastClickTime) < DOUBLE_CLICK_TIME then
            -- ── DOUBLE CLICK ──────────────────────────────────
            -- Remove old highlight
            if highlight then highlight:Destroy() end

            -- Add selection highlight
            highlight = Instance.new("SelectionBox")
            highlight.Adornee      = target
            highlight.Color3       = C.accent
            highlight.LineThickness = 0.05
            highlight.SurfaceTransparency = 0.8
            highlight.SurfaceColor3 = C.accent
            highlight.Parent       = workspace

            fillInspector(target)

            if not isOpen then
                setOpen(true)
            end

            lastClickedObj = nil
            lastClickTime  = 0
        else
            lastClickedObj = target
            lastClickTime  = now
        end
    else
        lastClickedObj = nil
    end
end)

