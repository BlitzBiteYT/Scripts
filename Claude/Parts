-- ─── ROW BUILDER ─────────────────────────────────────────────
local function makeRow(parent, key, value, order, isHeader)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, isHeader and 22 or 28)
    row.BackgroundColor3 = isHeader and C.header or (order % 2 == 0 and C.rowA or C.rowB)
    row.LayoutOrder      = order
    row.ZIndex           = 7
    row.Parent           = parent
    corner(row, 5)

    if isHeader then
        local hl = label(row, "  " .. key, 10, C.accent, true)
        hl.Size     = UDim2.new(1, 0, 1, 0)
        hl.ZIndex   = 8
        hl.TextYAlignment = Enum.TextYAlignment.Center
        return row
    end

    -- key
    local kl = label(row, key, 11, C.textDim, false)
    kl.Position = UDim2.new(0, 8, 0, 0)
    kl.Size     = UDim2.new(0, 130, 1, 0)
    kl.TextYAlignment = Enum.TextYAlignment.Center
    kl.ZIndex   = 8

    -- value
    local vl = label(row, tostring(value), 11, C.text, true, Enum.TextXAlignment.Right)
    vl.Position = UDim2.new(0, 138, 0, 0)
    vl.Size     = UDim2.new(1, -145, 1, 0)
    vl.TextYAlignment = Enum.TextYAlignment.Center
    vl.TextTruncate   = Enum.TextTruncate.AtEnd
    vl.ZIndex   = 8

    -- value colour coding
    if value == true  then vl.TextColor3 = C.green  end
    if value == false then vl.TextColor3 = C.red    end
    if type(value) == "number" then vl.TextColor3 = C.accent2 end

    return row, vl
end

-- ─── PATH BUILDER ────────────────────────────────────────────
local function getFullPath(inst)
    local path = inst.Name
    local cur  = inst.Parent
    while cur and cur ~= game do
        path = cur.Name .. "." .. path
        cur  = cur.Parent
    end
    return "game." .. path
end

local function getShortPath(inst)
    -- workspace.Model.Part style
    local path = inst.Name
    local cur  = inst.Parent
    local depth = 0
    while cur and cur ~= game and depth < 20 do
        path  = cur.Name .. " › " .. path
        cur   = cur.Parent
        depth = depth + 1
    end
    return path
end

-- ─── FORMAT HELPERS ──────────────────────────────────────────
local function fmtVec3(v)
    return string.format("%.3f, %.3f, %.3f", v.X, v.Y, v.Z)
end

local function fmtColor(c)
    return string.format("RGB(%d, %d, %d)", c.R*255, c.G*255, c.B*255)
end

local function fmtEnum(e)
    return tostring(e):match("%.(.+)$") or tostring(e)
end

local function countDescendants(inst)
    local n = 0
    for _ in pairs(inst:GetDescendants()) do n = n + 1 end
    return n
end

-- ─── POPULATE TABS ───────────────────────────────────────────
local lastRows = {}

local function clearPages()
    for _, page in ipairs(tabPages) do
        for _, child in ipairs(page:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
    end
    lastRows = {}
end

local function fillInspector(part)
    clearPages()

    BadgeName.Text     = part.Name
    BadgeDot.BackgroundColor3 = C.green

    local idx = 0
    local function row(page, key, value, isHeader)
        idx = idx + 1
        return makeRow(tabPages[page], key, value, idx, isHeader)
    end

    -- ── TAB 1: GENERAL ────────────────────────────────────────
    row(1, "IDENTITY", nil, true)
    row(1, "Name",           part.Name)
    row(1, "ClassName",      part.ClassName)
    row(1, "UniqueID",       tostring(part):match("0x%x+") or "N/A")

    row(1, "HIERARCHY", nil, true)
    row(1, "Parent",         part.Parent and part.Parent.Name or "nil")
    row(1, "Parent Class",   part.Parent and part.Parent.ClassName or "nil")
    row(1, "Depth",          (function()
        local d = 0; local c = part
        while c.Parent do c = c.Parent; d = d + 1 end
        return d
    end)())
    row(1, "Children",       #part:GetChildren())
    row(1, "Descendants",    countDescendants(part))
    row(1, "Tags",           #CollectionService and "N/A" or (function()
        local ok, svc = pcall(function() return game:GetService("CollectionService") end)
        if ok then
            local tags = svc:GetTags(part)
            return #tags > 0 and table.concat(tags, ", ") or "none"
        end
        return "N/A"
    end)())

    row(1, "PATH", nil, true)
    row(1, "Full Path",      getFullPath(part))
    row(1, "Short Path",     getShortPath(part))
    row(1, "Workspace?",     part:IsDescendantOf(workspace))
    row(1, "Archivable",     part.Archivable)

    -- ── TAB 2: TRANSFORM ──────────────────────────────────────
    row(2, "POSITION", nil, true)
    row(2, "Position",       fmtVec3(part.Position))
    row(2, "X",              math.round(part.Position.X * 1000) / 1000)
    row(2, "Y",              math.round(part.Position.Y * 1000) / 1000)
    row(2, "Z",              math.round(part.Position.Z * 1000) / 1000)

    row(2, "ROTATION", nil, true)
    local rx, ry, rz = part.CFrame:ToEulerAnglesXYZ()
    row(2, "Orientation",    fmtVec3(part.Orientation))
    row(2, "Rot X (rad)",    math.round(rx * 1000) / 1000)
    row(2, "Rot Y (rad)",    math.round(ry * 1000) / 1000)
    row(2, "Rot Z (rad)",    math.round(rz * 1000) / 1000)

    row(2, "SIZE", nil, true)
    row(2, "Size",           fmtVec3(part.Size))
    row(2, "Width (X)",      math.round(part.Size.X * 1000) / 1000)
    row(2, "Height (Y)",     math.round(part.Size.Y * 1000) / 1000)
    row(2, "Depth (Z)",      math.round(part.Size.Z * 1000) / 1000)

    row(2, "CFRAME", nil, true)
    row(2, "CFrame.X",       math.round(part.CFrame.X * 100) / 100)
    row(2, "CFrame.Y",       math.round(part.CFrame.Y * 100) / 100)
    row(2, "CFrame.Z",       math.round(part.CFrame.Z * 100) / 100)
    row(2, "LookVector",     fmtVec3(part.CFrame.LookVector))
    row(2, "RightVector",    fmtVec3(part.CFrame.RightVector))
    row(2, "UpVector",       fmtVec3(part.CFrame.UpVector))

    -- ── TAB 3: PHYSICS ────────────────────────────────────────
    row(3, "ANCHORING", nil, true)
    row(3, "Anchored",       part.Anchored)
    row(3, "CanCollide",     part.CanCollide)
    row(3, "CanTouch",       part.CanTouch)
    row(3, "CanQuery",       part.CanQuery)
    row(3, "Locked",         part.Locked)

    row(3, "MASS & INERTIA", nil, true)
    row(3, "Mass",           math.round(part:GetMass() * 1000) / 1000 .. " kg")
    row(3, "CustomPhysical", part.CustomPhysicalProperties ~= nil and "Yes" or "Default")
    row(3, "CenterOfMass",   fmtVec3(part:GetRootPart() == part and Vector3.new(0,0,0) or Vector3.new(0,0,0)))

    row(3, "VELOCITY", nil, true)
    row(3, "AssemblyVel",    fmtVec3(part.AssemblyLinearVelocity))
    row(3, "AngularVel",     fmtVec3(part.AssemblyAngularVelocity))

    row(3, "COLLISION", nil, true)
    row(3, "CollisionGroup", part.CollisionGroupId)
    row(3, "Massless",       part.Massless)
    row(3, "RootPriority",   part.RootPriority)

    -- ── TAB 4: APPEARANCE ─────────────────────────────────────
    row(4, "MATERIAL", nil, true)
    row(4, "Material",       fmtEnum(part.Material))
    row(4, "MaterialVariant", part.MaterialVariant ~= "" and part.MaterialVariant or "none")
    row(4, "Reflectance",    math.round(part.Reflectance * 100) .. "%")
    row(4, "Transparency",   math.round(part.Transparency * 100) .. "%")

    row(4, "COLOR", nil, true)
    row(4, "Color (RGB)",    fmtColor(part.Color))
    row(4, "Color (BrickColor)", tostring(part.BrickColor))
    row(4, "Hex Color",      string.format("#%02X%02X%02X",
        math.floor(part.Color.R * 255),
        math.floor(part.Color.G * 255),
        math.floor(part.Color.B * 255)))

    row(4, "SURFACE", nil, true)
    row(4, "CastShadow",     part.CastShadow)
    row(4, "TopSurface",     fmtEnum(part.TopSurface))
    row(4, "BottomSurface",  fmtEnum(part.BottomSurface))
    row(4, "FrontSurface",   fmtEnum(part.FrontSurface))
    row(4, "BackSurface",    fmtEnum(part.BackSurface))
    row(4, "LeftSurface",    fmtEnum(part.LeftSurface))
    row(4, "RightSurface",   fmtEnum(part.RightSurface))

    row(4, "SHAPE", nil, true)
    if part:IsA("Part") then
        row(4, "Shape",      fmtEnum(part.Shape))
    else
        row(4, "Shape",      "N/A (" .. part.ClassName .. ")")
    end

    -- ── TAB 5: SCRIPTS & ATTRIBUTES ───────────────────────────
    row(5, "ATTRIBUTES", nil, true)
    local attrs = part:GetAttributes()
    local attrCount = 0
    for k, v in pairs(attrs) do
        attrCount = attrCount + 1
        row(5, k, v)
    end
    if attrCount == 0 then
        row(5, "  (none)", "")
    end

    row(5, "SCRIPTS IN PART", nil, true)
    local scripts = {}
    for _, child in ipairs(part:GetDescendants()) do
        if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") then
            table.insert(scripts, child)
        end
    end
    if #scripts == 0 then
        row(5, "  (none)", "")
    else
        for _, s in ipairs(scripts) do
            row(5, s.Name, s.ClassName)
        end
    end

    row(5, "CONNECTIONS", nil, true)
    local conns = 0
    for _, child in ipairs(part:GetDescendants()) do
        if child:IsA("BindableEvent") or child:IsA("RemoteEvent") then
            conns = conns + 1
        end
    end
    row(5, "Events Found",   conns)
    row(5, "Touched Conn",   "client-side only")

    row(5, "MISC", nil, true)
    row(5, "NetworkOwner",   (function()
        local ok, owner = pcall(function() return part:GetNetworkOwner() end)
        if ok then
            return owner and owner.Name or "Server"
        end
        return "N/A"
    end)())
end

-- ─── PANEL SLIDE STATE ───────────────────────────────────────
local isOpen   = false
local tweening = false

local function setOpen(open)
    if tweening then return end
    tweening = true
    isOpen   = open

    local targetX  = open and 0 or -PANEL_WIDTH
    local arrowTxt = open and "❮" or "❯"
    local arrowX   = open and PANEL_WIDTH or 0

    local info = TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

    TweenService:Create(Panel, info, {
        Position = UDim2.new(0, targetX, 0.5, -(PANEL_HEIGHT / 2))
    }):Play()

    TweenService:Create(ArrowBtn, info, {
        Position = UDim2.new(0, arrowX, 0.5, -32)
    }):Play()

    task.delay(TWEEN_TIME, function()
        tweening        = false
        ArrowBtn.Text   = arrowTxt
    end)
end

ArrowBtn.MouseButton1Click:Connect(function()
    setOpen(not isOpen)
end)

CloseBtn.MouseButton1Click:Connect(function()
    setOpen(false)
end)

