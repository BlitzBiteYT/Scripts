end)

-- ─── NOTIFY ──────────────────────────────────────────────────
local function toast(msg)
    local toastFrame = Instance.new("Frame")
    toastFrame.Size             = UDim2.new(0, 240, 0, 36)
    toastFrame.Position         = UDim2.new(0.5, -120, 1, -60)
    toastFrame.BackgroundColor3 = Color3.fromRGB(20, 30, 55)
    toastFrame.ZIndex           = 20
    toastFrame.Parent           = ScreenGui
    corner(toastFrame, 8)
    stroke(toastFrame, C.accent, 1)

    local tl = label(toastFrame, msg, 12, C.text, true, Enum.TextXAlignment.Center)
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.TextYAlignment = Enum.TextYAlignment.Center
    tl.ZIndex = 21

    local info = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    toastFrame.Position = UDim2.new(0.5, -120, 1, 10)
    TweenService:Create(toastFrame, info, {
        Position = UDim2.new(0.5, -120, 1, -60)
    }):Play()

    task.delay(2.5, function()
        TweenService:Create(toastFrame, info, {
            Position = UDim2.new(0.5, -120, 1, 10)
        }):Play()
        task.delay(0.35, function() toastFrame:Destroy() end)
    end)
end

