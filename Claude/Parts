local function getAncestorChain(inst)
    local chain = {}
    local current = inst.Parent
    local depth = 0
    while current and current ~= game and depth < 10 do
        table.insert(chain, {name = current.Name, class = current.ClassName})
        current = current.Parent
        depth = depth + 1
    end
    if current == game then
        table.insert(chain, {name = "game", class = "DataModel"})
    end
    -- reverse
    local reversed = {}
    for i = #chain, 1, -1 do
        table.insert(reversed, chain[i])
    end
    return reversed
end

local function countDescendants(inst)
    local total = 0
    local function count(i)
        for _, child in ipairs(i:GetChildren()) do
            total = total + 1
            count(child)
        end
    end
    count(inst)
    return total
end

local function countChildrenByClass(inst)
    local classes = {}
    for _, child in ipairs(inst:GetChildren()) do
        classes[child.ClassName] = (classes[child.ClassName] or 0) + 1
    end
    return classes
end

local function getPhysicsInfo(part)
    local info = {}
    -- velocity if applicable
    pcall(function()
        info.AssemblyLinearVelocity = vec3ToString(part.AssemblyLinearVelocity)
        info.AssemblyAngularVelocity = vec3ToString(part.AssemblyAngularVelocity)
        info.AssemblyMass = string.format("%.4f", part.AssemblyMass)
    end)
    pcall(function()
        info.Mass = string.format("%.4f", part:GetMass())
    end)
    return info
end

local function getMaterialName(materialEnum)
    local name = tostring(materialEnum)
    return name:match("Enum%.Material%.(.+)") or tostring(materialEnum)
end

