    swatchBorder.Thickness = 1
    swatchBorder.Parent = swatch

    local hexLabel = Instance.new("TextLabel")
    hexLabel.Size = UDim2.new(0, 90, 1, 0)
    hexLabel.BackgroundTransparency = 1
    hexLabel.Text = color3ToHex(color)
    hexLabel.TextColor3 = Color3.fromRGB(220, 235, 255)
    hexLabel.TextSize = 10
    hexLabel.Font = Enum.Font.Code
    hexLabel.TextXAlignment = Enum.TextXAlignment.Right
    hexLabel.ZIndex = 3
    hexLabel.Parent = swatchHolder

    local sep = Instance.new("Frame")
    sep.Size = UDim2.new(1, -16, 0, 1)
    sep.Position = UDim2.new(0, 8, 1, -1)
    sep.BackgroundColor3 = Color3.fromRGB(30, 40, 60)
    sep.BackgroundTransparency = 0.5
    sep.BorderSizePixel = 0
    sep.ZIndex = 3
    sep.Parent = Row
end

-- ══════════════════════════════════════════
--           POPULATE INSPECTOR
-- ══════════════════════════════════════════

local function populateInspector(part)
    local gui = inspectorGui
    local cf = gui.ContentFrame

    -- Clear old content
    for _, child in ipairs(cf:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end
    rowCounter = 0

    local fullPath = getFullPath(part)
    local icon = getInstanceIcon(part)

    -- Update title
    gui.TitleLabel.Text = "PART INSPECTOR"
    gui.SubLabel.Text = icon .. "  " .. part.Name

    -- ── SECTION 1: IDENTITY ──
    local sec1 = createSection(cf, "Identity & Path", "🆔", "identity", 1)
    createRow(sec1, "Name", part.Name, 1, false)
    createRow(sec1, "ClassName", part.ClassName, 2, true)
    createRow(sec1, "UniqueId", tostring(part):match("0x%x+") or "N/A", 3, false)
    createRow(sec1, "Archivable", boolToStr(part.Archivable), 4, true)

    -- Tags
    local tags = Instance:GetTags and part:GetTags() or {}
    createRow(sec1, "Tags", #tags > 0 and table.concat(tags, ", ") or "none", 5, false)

    -- Attributes
    local attrs = part:GetAttributes()
    local attrCount = 0
    for _ in pairs(attrs) do attrCount = attrCount + 1 end
    createRow(sec1, "Attributes", attrCount .. " attribute(s)", 6, true)

    -- Full path row
    createPathRow(sec1, "📂 " .. fullPath, 7)

    -- ── SECTION 2: TRANSFORM ──
    if part:IsA("BasePart") then
        local sec2 = createSection(cf, "Transform", "📐", "transform", 2)
        local pos = part.Position
        local rot = part.CFrame:ToEulerAnglesXYZ()
        local rotDeg = Vector3.new(
            math.deg(rot),
            math.deg(select(2, part.CFrame:ToEulerAnglesXYZ())),
            math.deg(select(3, part.CFrame:ToEulerAnglesXYZ()))
        )
        createRow(sec2, "Position X", string.format("%.3f", pos.X), 1, false)
        createRow(sec2, "Position Y", string.format("%.3f", pos.Y), 2, true)
        createRow(sec2, "Position Z", string.format("%.3f", pos.Z), 3, false)
        createRow(sec2, "Rotation X°", string.format("%.2f°", math.deg(rot)), 4, true)
        local rx, ry, rz = part.CFrame:ToEulerAnglesXYZ()
        createRow(sec2, "Rotation Y°", string.format("%.2f°", math.deg(ry)), 5, false)
        createRow(sec2, "Rotation Z°", string.format("%.2f°", math.deg(rz)), 6, true)
        createRow(sec2, "Size X", string.format("%.3f", part.Size.X), 7, false)
        createRow(sec2, "Size Y", string.format("%.3f", part.Size.Y), 8, true)
        createRow(sec2, "Size Z", string.format("%.3f", part.Size.Z), 9, false)
        createRow(sec2, "Pivot Offset", tostring(part.PivotOffset), 10, true)
        createRow(sec2, "WorldCFrame", vec3ToString(part.CFrame.Position), 11, false)
    end

    -- ── SECTION 3: PHYSICS ──
    if part:IsA("BasePart") then
        local sec3 = createSection(cf, "Physics", "⚙️", "physics", 3)
        local physInfo = getPhysicsInfo(part)

        createRow(sec3, "Anchored", boolToStr(part.Anchored), 1, false)
        createRow(sec3, "CanCollide", boolToStr(part.CanCollide), 2, true)
        createRow(sec3, "CanTouch", boolToStr(part.CanTouch), 3, false)
        createRow(sec3, "CanQuery", boolToStr(part.CanQuery), 4, true)
        createRow(sec3, "CastShadow", boolToStr(part.CastShadow), 5, false)
        createRow(sec3, "Massless", boolToStr(part.Massless), 6, true)
        createRow(sec3, "Mass", physInfo.Mass or "N/A", 7, false)
        createRow(sec3, "Density", string.format("%.4f", part.CustomPhysicalProperties and
            part.CustomPhysicalProperties.Density or
            (pcall(function() return part.CurrentPhysicalProperties.Density end) and 1) or 1), 8, true)
        createRow(sec3, "Friction", string.format("%.3f",
            part.CustomPhysicalProperties and part.CustomPhysicalProperties.Friction or 0.3), 9, false)
        createRow(sec3, "Elasticity", string.format("%.3f",
            part.CustomPhysicalProperties and part.CustomPhysicalProperties.Elasticity or 0.5), 10, true)
        createRow(sec3, "Velocity", physInfo.AssemblyLinearVelocity or "N/A", 11, false)
        createRow(sec3, "AngVelocity", physInfo.AssemblyAngularVelocity or "N/A", 12, true)
        createRow(sec3, "AssemblyMass", physInfo.AssemblyMass or "N/A", 13, false)
    end

    -- ── SECTION 4: VISUAL ──
    if part:IsA("BasePart") then
        local sec4 = createSection(cf, "Visual & Material", "🎨", "visual", 4)
        createColorRow(sec4, "Color", part.Color, 1, false)
        createRow(sec4, "Material", getMaterialName(part.Material), 2, true)
        createRow(sec4, "Reflectance", string.format("%.3f", part.Reflectance), 3, false)
        createRow(sec4, "Transparency", string.format("%.3f", part.Transparency), 4, true)

        -- Check for special mesh
        local mesh = part:FindFirstChildOfClass("SpecialMesh")
        if mesh then
            createRow(sec4, "MeshType", tostring(mesh.MeshType):match("Enum%.MeshType%.(.+)") or tostring(mesh.MeshType), 5, false)
            createRow(sec4, "MeshScale", vec3ToString(mesh.Scale), 6, true)
            if mesh.MeshId ~= "" then
                createRow(sec4, "MeshId", mesh.MeshId:sub(1,40), 7, false)
            end
        end

        -- Check for SurfaceAppearance
        local sa = part:FindFirstChildOfClass("SurfaceAppearance")
        if sa then
            createRow(sec4, "SurfaceAppearance", "✔ Present", 8, true)
            createRow(sec4, "AlphaMode", tostring(sa.AlphaMode), 9, false)
        end

        createRow(sec4, "TopSurface", tostring(part.TopSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.TopSurface), 10, true)
        createRow(sec4, "BottomSurface", tostring(part.BottomSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.BottomSurface), 11, false)
        createRow(sec4, "FrontSurface", tostring(part.FrontSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.FrontSurface), 12, true)
        createRow(sec4, "BackSurface", tostring(part.BackSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.BackSurface), 13, false)
        createRow(sec4, "LeftSurface", tostring(part.LeftSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.LeftSurface), 14, true)
        createRow(sec4, "RightSurface", tostring(part.RightSurface):match("Enum%.SurfaceType%.(.+)") or tostring(part.RightSurface), 15, false)
    end

    -- ── SECTION 5: HIERARCHY ──
    local sec5 = createSection(cf, "Hierarchy & Lineage", "🌳", "hierarchy", 5)
    local ancestors = getAncestorChain(part)
    for i, anc in ipairs(ancestors) do
        local indent = string.rep("  ", i-1) .. (i == 1 and "" or "└ ")
        createRow(sec5, indent .. anc.class, anc.name, i, i % 2 == 0)
    end
    createRow(sec5, "└ " .. part.ClassName, "★ " .. part.Name, #ancestors + 1, (#ancestors + 1) % 2 == 0)
    createRow(sec5, "Depth Level", tostring(#ancestors + 1), #ancestors + 2, (#ancestors + 2) % 2 == 0)
    createRow(sec5, "Parent", part.Parent and part.Parent.Name or "nil", #ancestors + 3, (#ancestors + 3) % 2 == 0)
    createRow(sec5, "Parent Class", part.Parent and part.Parent.ClassName or "nil", #ancestors + 4, (#ancestors + 4) % 2 == 0)

    -- ── SECTION 6: CHILDREN STATS ──
    local children = part:GetChildren()
    local desc = countDescendants(part)
    local childClasses = countChildrenByClass(part)

    local sec6 = createSection(cf, "Children & Descendants", "👶", "children", 6)
    createRow(sec6, "Direct Children", tostring(#children), 1, false)
    createRow(sec6, "All Descendants", tostring(desc), 2, true)

    local ci = 3
    for class, count in pairs(childClasses) do
        createRow(sec6, "  " .. class, tostring(count) .. "x", ci, ci % 2 == 0)
        ci = ci + 1
    end

    -- ── SECTION 7: ATTRIBUTES (Detail) ──
    if attrCount > 0 then
        local sec7 = createSection(cf, "Attributes (Detail)", "🏷️", "attributes", 7)
        local ai = 1
        for attrName, attrVal in pairs(attrs) do
            local valStr
            local t = typeof(attrVal)
            if t == "Color3" then
                valStr = color3ToHex(attrVal)
            elseif t == "Vector3" then
                valStr = vec3ToString(attrVal)
            elseif t == "number" then
                valStr = string.format("%.4f", attrVal)
            elseif t == "boolean" then
                valStr = boolToStr(attrVal)
            else
                valStr = tostring(attrVal)
            end
            createRow(sec7, "[" .. t .. "] " .. attrName, valStr, ai, ai % 2 == 0)
            ai = ai + 1
        end
    end

    -- ── SECTION 8: MISC / SCRIPT RELATIONS ──
    local sec8 = createSection(cf, "Misc Info", "ℹ️", "misc", 8)
    createRow(sec8, "IsDescendantOf WS", boolToStr(part:IsDescendantOf(workspace)), 1, false)
    createRow(sec8, "IsDescendantOf SG", boolToStr(part:IsDescendantOf(LocalPlayer.PlayerGui)), 2, true)
    createRow(sec8, "IsDescendantOf PS", boolToStr(part:IsDescendantOf(LocalPlayer.PlayerScripts)), 3, false)

    -- Check if part is a character part
    local char = LocalPlayer.Character
    local isCharPart = char and part:IsDescendantOf(char)
    createRow(sec8, "Is Character Part", boolToStr(isCharPart or false), 4, true)

    -- Distance from camera
    local camPos = Camera.CFrame.Position
    local partPos = part.Position or part:GetPivot().Position
    local dist = (camPos - partPos).Magnitude
    createRow(sec8, "Dist from Camera", string.format("%.2f studs", dist), 5, false)

    -- Check for scripts
    local hasScript = part:FindFirstChildOfClass("Script") ~= nil
    local hasLS     = part:FindFirstChildOfClass("LocalScript") ~= nil
    local hasMod    = part:FindFirstChildOfClass("ModuleScript") ~= nil
    createRow(sec8, "Has Script",       boolToStr(hasScript), 6, true)
    createRow(sec8, "Has LocalScript",  boolToStr(hasLS), 7, false)
    createRow(sec8, "Has ModuleScript", boolToStr(hasMod), 8, true)

    -- Weld count
    local weldCount = 0
    for _, c in ipairs(part:GetChildren()) do
        if c:IsA("WeldConstraint") or c:IsA("Weld") or c:IsA("Motor6D") then
            weldCount = weldCount + 1
        end
    end
    createRow(sec8, "Weld/Constraint Count", tostring(weldCount), 9, false)

    -- Lights
    local lightCount = 0
    for _, c in ipairs(part:GetChildren()) do
        if c:IsA("Light") then lightCount = lightCount + 1 end
    end
    createRow(sec8, "Light Sources", tostring(lightCount), 10, true)

    -- Copy button functionality
    gui.CopyBtn.MouseButton1Click:Connect(function()
        local info = string.format(
            "=== PART INSPECTOR EXPORT ===\n"..
            "Name: %s\n"..
            "ClassName: %s\n"..
            "Path: %s\n"..
            "Position: %s\n"..
            "Size: %s\n"..
            "Color: %s\n"..
            "Material: %s\n"..
            "Anchored: %s\n"..
            "Transparency: %.3f\n"..
            "Children: %d\n"..
            "Descendants: %d\n",
            part.Name,
            part.ClassName,
            fullPath,
            part:IsA("BasePart") and vec3ToString(part.Position) or "N/A",
            part:IsA("BasePart") and vec3ToString(part.Size) or "N/A",
            part:IsA("BasePart") and color3ToHex(part.Color) or "N/A",
            part:IsA("BasePart") and getMaterialName(part.Material) or "N/A",
            part:IsA("BasePart") and tostring(part.Anchored) or "N/A",
            part:IsA("BasePart") and part.Transparency or 0,
            #children,
            desc
        )
        -- Try to use setclipboard if available in executor
        if setclipboard then
            setclipboard(info)
            gui.CopyBtn.Text = "✔"
            task.delay(1.5, function()
                if gui.CopyBtn then
                    gui.CopyBtn.Text = "📋"
                end
            end)
        end
    end)
end

-- ══════════════════════════════════════════
--        LIVE-UPDATE LOOP (Position/Velocity)
-- ══════════════════════════════════════════

local function startLiveUpdate(part)
    if updateConnection then
        updateConnection:Disconnect()
        updateConnection = nil
    end
    -- We don't repopulate entirely every frame (too heavy), just update key labels live
    -- This is a lightweight version that just refreshes position every 0.1s
    local last = tick()
    updateConnection = RunService.Heartbeat:Connect(function()
        if not (isOpen and selectedPart and selectedPart.Parent) then
            if updateConnection then
                updateConnection:Disconnect()
                updateConnection = nil
            end
            return
        end
        -- If part gets destroyed
        if not selectedPart.Parent then
            clearHighlight()
            isOpen = false
            inspectorGui.MainFrame.Visible = false
        end
    end)
end

-- ══════════════════════════════════════════
--           DOUBLE-CLICK DETECTION
-- ══════════════════════════════════════════

inspectorGui = createInspectorGui()

-- Animate open
local function openInspector(part)
    selectedPart = part
    highlightPart(part)
    populateInspector(part)
    inspectorGui.MainFrame.Visible = true
    isOpen = true

    -- Animate in
    inspectorGui.MainFrame.Size = UDim2.new(0, CONFIG.UIWidth, 0, 0)
    inspectorGui.MainFrame.BackgroundTransparency = 1
    local tween = TweenService:Create(inspectorGui.MainFrame,
        TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, CONFIG.UIWidth, 0, CONFIG.UIHeight),
            BackgroundTransparency = 0,
        }
    )
    tween:Play()

    startLiveUpdate(part)
end

local clickCount = 0
local clickTimer = nil

Mouse.Button1Down:Connect(function()
    local target = Mouse.Target
    if not target then return end

    clickCount = clickCount + 1

    if clickCount == 1 then
        clickTimer = task.delay(CONFIG.DoubleClickTime, function()
            clickCount = 0
        end)
    elseif clickCount >= 2 then
        if clickTimer then
            task.cancel(clickTimer)
            clickTimer = nil
        end
        clickCount = 0

        -- Double click detected!
        openInspector(target)
    end
end)

